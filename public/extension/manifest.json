{
  "manifest_version": 3,
  "name": "AI Radar — Real-Time Content Shield",
  "version": "2.2.0",
  "description": "Brauzerdagi behayo, zo'ravonlik va zararli kontentni real vaqtda bloklaydi. v2.2: lokal model ichida, pre-block, fail-closed strict himoya.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["shield.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["nsfw-loader.js", "vendor/tf.min.js", "vendor/nsfwjs.min.js", "vendor/nsfw-model/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "AI Radar",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
