{
  "manifest_version": 3,
  "name": "AI Radar — Real-Time Content Shield",
  "version": "1.0.0",
  "description": "Har qanday veb-saytdagi behayo, zo'ravonlik va zararli rasm/videolarni AI orqali real vaqtda aniqlab bloklaydi (Pinterest, Instagram, Facebook va boshqalar).",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["shield.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "AI Radar",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
