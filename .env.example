# Copy to `.env` for Vite (Supabase anon URL/key only — never AI secrets in frontend).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Edge Functions secrets (Supabase Dashboard → Project → Edge Functions → Secrets),
# or: `supabase secrets set GEMINI_API_KEY=... GROQ_API_KEY=...` before deploy.

GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
LOVABLE_API_KEY=

# Optional model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
# OPENROUTER_VIDEO_MODEL=openai/gpt-4o

# Comma-separated provider order (text / image default: groq,openrouter,gemini,lovable)
# AI_PROVIDER_ORDER_TEXT=groq,openrouter,gemini,lovable
# AI_PROVIDER_ORDER_IMAGE=groq,openrouter,gemini,lovable

# Video: Gemini handles native video best; defaults: gemini,openrouter,lovable
# AI_PROVIDER_ORDER_VIDEO=gemini,openrouter,lovable

# OPENROUTER_SITE_URL=https://localhost
# OPENROUTER_APP_NAME=Content Insight AI
